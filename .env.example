# MCP Proxy Server - Environment Configuration

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Proxy server's canonical URL (used for audience validation)
PROXY_URL=https://proxy.example.com

# Upstream MCP server URL to proxy requests to
UPSTREAM_MCP_URL=https://mcp.example.com


# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Address to listen on (default: :8443)
LISTEN_ADDR=:8443

# TLS certificate and key files (required for HTTPS)
# Leave empty for HTTP in development (NOT recommended for production)
TLS_CERT_FILE=./certs/cert.pem
TLS_KEY_FILE=./certs/key.pem

# Graceful shutdown timeout (default: 30s)
SHUTDOWN_TIMEOUT=30s


# =============================================================================
# TOKEN CONFIGURATION
# =============================================================================

# Opaque bearer token time-to-live (default: 15m)
# Format: duration string (e.g., "15m", "1h", "900s")
OPAQUE_TOKEN_TTL=15m


# =============================================================================
# CRYPTOGRAPHY & KEY MANAGEMENT
# =============================================================================

# Key store type: "memory", "file", or "kms"
# - memory: In-memory (lost on restart, dev only)
# - file: JSON file on disk (single-server deployments)
# - kms: Key Management Service (production, not yet implemented)
KEY_STORE_TYPE=file

# Path to key store file (required if KEY_STORE_TYPE=file)
KEY_STORE_PATH=./keys.json


# =============================================================================
# RATE LIMITING
# =============================================================================

# Enable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# Requests per second (default: 100)
RATE_LIMIT_RPS=100

# Burst size (default: 200)
RATE_LIMIT_BURST=200


# =============================================================================
# LOGGING
# =============================================================================

# Log level: "debug", "info", "warn", "error" (default: info)
LOG_LEVEL=info

# Log format: "json" or "text" (default: json)
LOG_FORMAT=json


# =============================================================================
# CORS (for browser-based MCP clients like MCP Inspector)
# =============================================================================

# Enable CORS support (default: false; configure allowed_origins in config.yaml)
# MCP_PROXY_CORS_ENABLED=true


# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# For local development without TLS:
# LISTEN_ADDR=:8080
# TLS_CERT_FILE=
# TLS_KEY_FILE=
# PROXY_URL=http://localhost:8080


# =============================================================================
# PRODUCTION EXAMPLE
# =============================================================================

# LISTEN_ADDR=:443
# TLS_CERT_FILE=/etc/letsencrypt/live/proxy.example.com/fullchain.pem
# TLS_KEY_FILE=/etc/letsencrypt/live/proxy.example.com/privkey.pem
# PROXY_URL=https://proxy.example.com
# UPSTREAM_MCP_URL=https://mcp.example.com
# KEY_STORE_TYPE=file
# KEY_STORE_PATH=/var/lib/mcpproxy/keys.json
# OPAQUE_TOKEN_TTL=15m
# LOG_LEVEL=info
# LOG_FORMAT=json
