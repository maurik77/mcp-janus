{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch proxy",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/proxy",
      "env": {
        "MCP_IDP_CLIENT_SECRET": "${input:clientSecret}",
      },
    },
    {
      "name": "Launch proxy (HTTPS)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/proxy",
      "env": {
        "MCP_LISTEN_ADDR": ":443",
        "MCP_TLS": "true",
        "MCP_TLS_CERT_FILE": "${workspaceFolder}/localhost+2.pem",
        "MCP_TLS_KEY_FILE": "${workspaceFolder}/localhost+2-key.pem",
        "MCP_IDP_CLIENT_SECRET": "${input:clientSecret}"
      },
      "args": [],
      "showLog": true,
      "trace": "verbose",
      "logOutput": "debugger"
    },
  ],
  "inputs": [
    {
      "id": "clientSecret",
      "type": "promptString",
      "description": "Authentication Server Client Secret"
    }
  ]
}